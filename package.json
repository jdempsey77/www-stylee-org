{
  "name": "www-stylee-org",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "build:staging": "NODE_ENV=staging CUSTOM_DOMAIN=false next build",
    "build:prod": "NODE_ENV=production next build",
    "export": "next build",
    "export:staging": "NODE_ENV=staging CUSTOM_DOMAIN=false next build",
    "export:prod": "NODE_ENV=production next build",
    "start": "next start",
    "start:staging": "NODE_ENV=staging next start",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "audit": "npm audit --audit-level moderate",
    "audit:fix": "npm audit fix",
    "test:build": "npm run build:staging && npm run validate:build",
    "validate:build": "node scripts/validate-build.js",
    "serve:staging": "npx serve out -p 3001",
    "preview": "npm run build:staging && npm run serve:staging",
    "test:local": "npm run lint && npm run audit && npm run test:build",
    "test:quick": "npm run lint && npm run build:staging",
    "dev:test": "npm run lint && npm run dev",
    "staging:full": "npm run test:local && npm run preview",
    "dev:workflow": "node scripts/dev-workflow.js",
    "serve:local": "./scripts/serve-local.sh",
    "watch:files": "./scripts/watch-files.sh",
    "resume:smart": "node scripts/smart-resume-pipeline.js",
    "pipeline:production": "node scripts/production-pipeline.js",
    "setup:hooks": "./scripts/setup-pre-push-hook.sh",
    "test:production": "npm run pipeline:production",
    "docs": "echo '📚 Documentation available in docs/ directory:' && ls docs/",
    "clean:all": "rm -rf .next out node_modules && npm cache clean --force",
    "setup:all": "npm install && npm run setup:hooks",
    "status": "echo '📊 Project Status:' && git status --short && echo '📦 Dependencies:' && npm list --depth=0",
    "security": "node scripts/security-scanner.js"
  },
  "dependencies": {
    "@heroicons/react": "^2.2.0",
    "@types/dompurify": "^3.0.5",
    "dompurify": "^3.4.0",
    "googleapis": "^160.0.0",
    "gtag": "^1.0.1",
    "next": "^15.5.18",
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^20.19.26",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^15.5.9",
    "puppeteer": "^24.33.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
